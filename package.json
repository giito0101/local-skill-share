{
  "name": "local-skill-share",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "//db": "=== DB ===",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "//local": "=== Local ===",
    "local:db:reset": "dotenv -e .env.local -- prisma db push --force-reset",
    "local:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "local:db:seed": "dotenv -e .env.local -- prisma db seed",
    "local:setup": "npm run local:db:reset && npm run local:db:seed",
    "dev": "next dev",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "//e2e": "=== E2E (CI) ===",
    "e2e": "playwright test --workers=1",
    "//product": "=== Product ===",
    "prod:migrate": "dotenv -e .env.prod -- prisma migrate deploy",
    "prod:seed": "dotenv -e .env.prod -- prisma db seed",
    "build": "prisma generate && next build",
    "start": "next start"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@vercel/blob": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "next": "^16.0.10",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "jsdom": "^27.3.0",
    "prisma": "^7.1.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.2",
    "vitest": "^4.0.16"
  }
}
